# ── LLM Configuration ──
# Supports any OpenAI-compatible API provider.
# Examples:
#   Qwen:     LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   OpenAI:   LLM_BASE_URL=https://api.openai.com/v1                               LLM_MODEL=gpt-4o
#   Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1                          LLM_MODEL=llama-3.3-70b-versatile
#   DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1                             LLM_MODEL=deepseek-chat
#   Ollama:   LLM_BASE_URL=http://localhost:11434/v1                                LLM_MODEL=llama3

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=llm-model
